{
  "name": "agent-runtime-kit",
  "version": "0.0.0-semantically-released",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WillBooster/agent-runtime-kit.git"
  },
  "license": "Apache-2.0",
  "author": "WillBooster Inc.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "build-ts lib",
    "cleanup": "bun --bun wb lint --fix --format",
    "format": "bun --bun wb lint --format",
    "lint": "bun --bun wb lint",
    "lint-fix": "bun --bun wb lint --fix",
    "prepare": "lefthook install || true",
    "release": "semantic-release",
    "test": "bun wb test",
    "test:e2e-github": "bun test test/e2e/githubPr.test.ts",
    "typecheck": "bun --bun wb typecheck",
    "verify": "bun --bun wb verify",
    "verify-full": "bun --bun wb verify --full"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.120",
    "@openai/codex-sdk": "0.125.0"
  },
  "devDependencies": {
    "@tsconfig/bun": "1.0.10",
    "@types/bun": "1.3.13",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "@willbooster/oxfmt-config": "1.2.2",
    "@willbooster/oxlint-config": "1.4.6",
    "@willbooster/wb": "13.12.10",
    "build-ts": "17.1.10",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "lefthook": "2.1.6",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "oxlint-tsgolint": "0.22.1",
    "semantic-release": "25.0.3",
    "sort-package-json": "3.6.1"
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  }
}
